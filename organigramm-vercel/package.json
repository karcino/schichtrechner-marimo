{
  "name": "organigramm-ad-vercel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run gen:public && next dev",
    "dev:private": "BUILD_MODE=private npm run gen:private && BUILD_MODE=private next dev",
    "build": "npm run gen:public && next build",
    "build:public": "npm run gen:public && next build",
    "build:private": "BUILD_MODE=private npm run gen:private && BUILD_MODE=private next build",
    "start": "next start",
    "lint": "next lint",
    "gen:public": "BUILD_MODE=public node scripts/generate-enrichments.mjs",
    "gen:private": "BUILD_MODE=private node scripts/generate-enrichments.mjs",
    "check:no-private-leaks": "node scripts/check-no-private-leaks.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@supabase/supabase-js": "^2.104.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
